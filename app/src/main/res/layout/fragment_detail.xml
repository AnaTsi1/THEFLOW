<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingTop="14dp"
        android:paddingRight="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/detail_IMG_header"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:background="@drawable/bg_media_gradient"
            android:gravity="center"
            android:text="DANCE"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_LBL_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_LBL_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/detail_LBL_schedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/detail_BTN_save"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_primary"
            android:text="Save"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/detail_BTN_follow"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Follow Studio"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/detail_BTN_claim_studio"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:text="Claim Studio"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/detail_BTN_back"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Back"
            android:textColor="@color/text_secondary" />

    </LinearLayout>
</ScrollView>
