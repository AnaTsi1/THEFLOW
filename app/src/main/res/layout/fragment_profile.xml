<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingLeft="16dp"
    android:paddingTop="14dp"
    android:paddingRight="16dp"
    android:paddingBottom="88dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_highlight"
            android:orientation="vertical"
            android:padding="18dp">

            <ImageView
                android:id="@+id/profile_IMG_cover"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:background="@drawable/bg_media_gradient"
                android:contentDescription="Cover image"
                android:scaleType="centerCrop" />

            <ImageView
                android:id="@+id/profile_IMG_avatar"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_marginTop="-30dp"
                android:background="@drawable/bg_avatar"
                android:contentDescription="Profile photo"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/profile_LBL_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/profile_BTN_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_secondary"
                    android:contentDescription="Settings"
                    android:padding="10dp"
                    android:src="@drawable/ic_settings_24" />
            </LinearLayout>

            <Button
                android:id="@+id/profile_BTN_edit"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_button_secondary"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Edit Profile"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/profile_LBL_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/profile_LBL_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_LAY_sections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Professional Details"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profile_LBL_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/profile_LBL_skills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_LAY_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit Public Profile"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profile_LBL_editPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Add only what you want people to see on your public profile."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/profile_BTN_profilePhoto"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Choose Profile Photo"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/profile_BTN_coverImage"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Choose Cover Image"
                android:textColor="@color/text_primary" />

            <EditText
                android:id="@+id/profile_EDT_bio"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Bio"
                android:inputType="textMultiLine"
                android:paddingTop="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <EditText
                android:id="@+id/profile_EDT_background"
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Professional background"
                android:inputType="textMultiLine"
                android:paddingTop="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <EditText
                android:id="@+id/profile_EDT_skills"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Skills / specialties, comma separated"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/profile_BTN_cancelEdit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:text="Cancel"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/profile_BTN_saveEdit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_primary"
                    android:text="Save"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_LAY_mediaSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Media"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/profile_BTN_openMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="View all"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/profile_LAY_mediaStrip"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/profile_LAY_mediaPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="All Media"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/profile_BTN_closeMedia"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_button_secondary"
                        android:minWidth="0dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Close"
                        android:textAllCaps="false"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/profile_LAY_mediaGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Post"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/profile_EDT_postText"
                android:layout_width="match_parent"
                android:layout_height="104dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="What's on your mind?"
                android:inputType="textMultiLine"
                android:paddingTop="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted" />

            <TextView
                android:id="@+id/profile_LBL_selectedMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/profile_BTN_postMedia"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="0dp"
                    android:text="Photo / Video"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/profile_BTN_postActivity"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginHorizontal="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="0dp"
                    android:text="Dance Activity"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/profile_BTN_postCollaboration"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:minWidth="0dp"
                    android:text="Collaboration"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profile_LAY_activityFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <AutoCompleteTextView
                    android:id="@+id/profile_EDT_activityType"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input"
                    android:hint="Activity type"
                    android:inputType="none"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <AutoCompleteTextView
                    android:id="@+id/profile_EDT_activityLocation"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Location"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_activityDate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Date"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_activityTime"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Time"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_activityPrice"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Price"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_activityLevel"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Level"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_activityDescription"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:hint="Activity description"
                    android:inputType="textMultiLine"
                    android:paddingTop="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profile_LAY_collaborationFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/profile_EDT_collaborationLookingFor"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input"
                    android:hint="Looking for"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_collaborationStyle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Style"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <AutoCompleteTextView
                    android:id="@+id/profile_EDT_collaborationLocation"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Location"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_collaborationDate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Date / deadline"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <AutoCompleteTextView
                    android:id="@+id/profile_EDT_collaborationPaid"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="Paid or unpaid"
                    android:inputType="none"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />

                <EditText
                    android:id="@+id/profile_EDT_collaborationDescription"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top"
                    android:hint="Collaboration description"
                    android:inputType="textMultiLine"
                    android:paddingTop="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted" />
            </LinearLayout>

            <Button
                android:id="@+id/profile_BTN_createPost"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="Post"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_card" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Posts" android:textColor="@color/text_primary" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:id="@+id/profile_LBL_postsEmpty" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="No posts yet." android:textColor="@color/text_muted" android:textSize="14sp" />
            <LinearLayout android:id="@+id/profile_LAY_posts" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
