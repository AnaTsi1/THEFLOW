<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="88dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_highlight"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/profile_LBL_cover"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:background="@drawable/bg_media_gradient"
                android:gravity="center"
                android:text="Cover image"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profile_IMG_placeholder"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_marginTop="-34dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="ME"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/profile_LBL_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/profile_BTN_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_secondary"
                    android:contentDescription="Settings"
                    android:padding="10dp"
                    android:src="@drawable/ic_settings_24" />
            </LinearLayout>

            <TextView
                android:id="@+id/profile_LBL_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/profile_LBL_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/profile_LBL_completeCta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_chip"
                android:padding="14dp"
                android:text="Complete your dancer profile"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/profile_LBL_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/profile_BTN_edit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_primary"
                    android:text="Edit Profile"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_LAY_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Edit Professional Profile" android:textColor="@color/text_primary" android:textSize="19sp" android:textStyle="bold" />
            <EditText android:id="@+id/profile_EDT_firstName" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="14dp" android:background="@drawable/bg_input" android:hint="First name" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_lastName" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Last name" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_birthDate" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Birth date" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_age" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Age" android:inputType="number" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_headline" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Headline" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_about" android:layout_width="match_parent" android:layout_height="96dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:gravity="top" android:hint="About / bio" android:inputType="textMultiLine" android:paddingTop="12dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_styles" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Dance styles, comma separated" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_level" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Level" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_years" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Years of experience" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_location" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Location" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_studios" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Studios trained at" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_teachers" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Teachers learned from" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_performances" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Performances / competitions" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_availability" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Availability" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_instagram" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="Instagram" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_tiktok" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="TikTok" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <EditText android:id="@+id/profile_EDT_youtube" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:hint="YouTube" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Create Post" android:textColor="@color/text_primary" android:textSize="19sp" android:textStyle="bold" />
            <EditText android:id="@+id/profile_EDT_newPost" android:layout_width="match_parent" android:layout_height="96dp" android:layout_marginTop="12dp" android:background="@drawable/bg_input" android:gravity="top" android:hint="Share an update, video note, class recap, or collaboration request" android:inputType="textMultiLine" android:paddingTop="12dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted" />
            <Button android:id="@+id/profile_BTN_createPost" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="12dp" android:background="@drawable/bg_button_primary" android:text="Post" android:textColor="@color/text_primary" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/profile_LAY_sections" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_card" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Professional Details" android:textColor="@color/text_primary" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:id="@+id/profile_LBL_details" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:lineSpacingExtra="4dp" android:textColor="@color/text_secondary" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_card" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Posts" android:textColor="@color/text_primary" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:id="@+id/profile_LBL_postsEmpty" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="No posts yet." android:textColor="@color/text_muted" android:textSize="14sp" />
            <LinearLayout android:id="@+id/profile_LAY_posts" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
